<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="640.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxtest.UIControllers.MainLayoutController">
  <children>
    <ToolBar prefHeight="40.0" prefWidth="200.0">
      <items>
        <Button mnemonicParsing="false" onAction="#showOSDetails" text="OS Details" style="-fx-cursor: hand;" />
        <Button mnemonicParsing="false" onAction="#showCPUDetails" text="CPU Details" style="-fx-cursor: hand;" />
      </items>
    </ToolBar>
    
    <AnchorPane fx:id="contentArea" VBox.vgrow="ALWAYS" />
  </children>
</VBox>
