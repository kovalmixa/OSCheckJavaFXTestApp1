<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CustomMenuItem?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="400.0" prefWidth="640.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxtest.ui_controllers.MainLayoutController">
  <children>
    <HBox spacing="10" style="-fx-padding: 10;">
      <children>
        <Button mnemonicParsing="false" onAction="#showOSInformation" style="-fx-cursor: hand;" text="OS Details" />
        <MenuButton mnemonicParsing="false" text="CPU Menu">
          <items>
            <CustomMenuItem hideOnClick="false">
              <content>
                <Button onAction="#showCpuInformation" prefWidth="100" text="Information" />
              </content>
            </CustomMenuItem>
            <CustomMenuItem hideOnClick="false">
              <content>
                <Button onAction="#showCpuLoad" prefWidth="100" text="CPU Loading" />
              </content>
            </CustomMenuItem>
          </items>
        </MenuButton>
      </children>
    </HBox>
    <AnchorPane fx:id="contentArea" VBox.vgrow="ALWAYS" />
  </children>
</VBox>
